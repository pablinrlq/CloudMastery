# Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Connection string "Session pooler" (botão Connect no topo do dashboard).
# Usada só pelo script db/run-migrations.mjs.
DATABASE_URL=
# Service role key: server-only, never expose to the client. Used to grade
# simulados and read the question bank without leaking answers via RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (Developers > API keys)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Developers > Webhooks > signing secret (or from `stripe listen` in dev)
STRIPE_WEBHOOK_SECRET=
# Price IDs from Products > your subscription product
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_ANNUAL=

# Used to build absolute URLs for Stripe redirect/webhook callbacks
NEXT_PUBLIC_SITE_URL=http://localhost:3000
